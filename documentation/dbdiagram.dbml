// Table storing company metadata along with detected technologies.
// Each row represents a (domain, technology) pair.

Table companies {

  // Company domain (always present)
  domain text [not null, note: "Primary identifier for a company"]

  // Basic company information
  companyName text [note: "Human readable company name"]
  companyCategory text [note: "Industry or category the company belongs to"]

  // Location data
  city text
  state text
  country text [note: "Country where the company operates"]
  zipcode text

  // Technology detected on the company's website
  tech text [note: "Technology used by the company. May be NULL if no technology detected"]

  // High-level grouping of technologies
  techCategory text [note: "Category of the technology (e.g. Analytics, CMS, Payments)"]

  // Composite primary key
  // Ensures each domain-technology pair appears only once
  Indexes {
    (domain, tech) [pk, note: "Composite primary key ensuring unique domain-technology pair"]

    companyCategory [note: "Helps filtering companies by industry/category"]

    country [note: "Optimizes country-based filtering queries"]

    tech [note: "Speeds up queries searching companies using a specific technology"]

    techCategory [note: "Optimizes technology category based filtering"]
  }
}